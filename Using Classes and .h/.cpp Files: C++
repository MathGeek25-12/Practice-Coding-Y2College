#include "Student1.h"
#include "Course.h"
#include <iostream>
#include <string>

Student1::Student1() {
	this->major = "Blank";
	this->GPA = 0;
}

Student1::Student1(std::string major, float GPA, Course) {
	this->major = major;
	this->GPA = GPA;
	this->Course = Course;
}

void Student1::PrintStudent() {
	std::cout << "Major: " << this->major;
	std::cout << "GPA: " << this->GPA;
	std::cout << "Courses: " << this->Course;
}

void Student1::register(Course course) {
	this->transcript[courseCount++] = course;
}

void Student1::setMajor(std::string major) {
	this->major = major;
}

void Student1::setGPA(float GPA);

void Student1::CalculateGPA() {
	float GPA = 0;
	int totalCredits = 0;
	for (int i = 0; i < courseCount; i++) {
		GPA += transcript[i].GetCredits() * transcript[i].GetGrade();
		totalCredits += transcript[i].GetCredits();
	}
	this->GPA = GPA / totalCredits;
}

void Student1::Course(Course);

