//Set all the ages, resistances, and weapons into random functions to create unique humans
Humans1::Humans1() {
	//Sets the ages for the calculatePoints function -- creates a list
	std::string ages[] = { "Baby", "Teenager", "Young Adult", "Adult" , "Elderly" };

	//Set the resistant or armor types for the calculatePoints function -- creates a list
	std::string resistances[] = { "normal clothes", "leather hide", "biking gear", "army gear" };

	//Set the weapon types into a list for the calculatePoints function
	std::string weapons[] = { "hands", "bat", "knife", "gun" };

	//Set up the random function to put these attributes to the humans
	age = ages[rand() % 5];
	resistance = resistances[rand() % 4];
	weapon = weapons[rand() % 4];

	calculatePoints();
}

void Humans1::calculatePoints() {
	//Set the base points
	points = 0;
	points = getWeapons(weapon)
		+ getResistance(resistance)
		+ getAge(age);
}

int Humans1::getWeapons(const std::string& weapon) const {
	//set up the points for weapons
	if (weapon == "gun") return 5;
	else if (weapon == "knife") return 3;
	else if (weapon == "bat") return 2;
	else if (weapon == "hands") return 0;
	return 0;
}

int Humans1::getResistance(const std::string& resistance) const {
	//set up the points for resistance/armour
	if (resistance == "army gear") return 5;
	else if (resistance == "biking gear") return 3;
	else if (resistance == "leather hide") return 2;
	else if (resistance == "normal clothes") return 0;
	return 0;
}

int Humans1::getAge(const std::string& age) const {
	//set up points for age
	if (age == "Young Adult") return 5;
	else if (age == "Teenager") return 3;
	else if (age == "Adult") return 4;
	else if (age == "Elderly") return 2;
	else if (age == "Baby") return 0;
	return 0;
}

//Will gather the amount of points
int Humans1::getPoints() const {
	return points;
}

//Gives different symbols based on the amount of points a human has
char Humans1::Infect_ed() {
	if (points <= 0) {
		return '.';
	}
	else if (points <= 3) {
		return '*';
	}
	else if (points <= 6) {
		return 'h';
	}
	else if (points <= 12) {
		return 'H';
	}
	else if (points <= 15) {
		return 'S';
	}
	//Sets up a fail safe to alert whether the code is working
	else {
		return -1;
	}
}

