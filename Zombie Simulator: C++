//Populates the Array with random numbers
//Problem number 1
void PopArray(int Array[10][10], int rows, int cols) {
	for (int i = 0; i < rows; i++) {
		for (int j = 0; j < cols; j++) {
			Array[i][j] = rand() % 89 + 11;
		}
	}
}

