//MainFunction file

#include "Humans1.h"
#include "Points1.h"
#include "Zombies1.h"

#include <iostream>
#include <ctime>
#include <vector>
#include <cstdlib>

using namespace std;

//Use global variables
int x, y, zzX, zzY;
//Functions to run the code
void checkArgs();
vector<vector<Points1*>> initWorld();
void printWorld(const vector<vector<Points1*>>& World);
void infect(vector<vector<Points1*>>& World);

int main(int argc, char* argv[])
{
	//Include random time
	srand(static_cast<unsigned int>(time(0)));

	//Command line arguments to make the grid with vertical and horizontal rows
	x = atoi(argv[1]); //2D vector row count
	y = atoi(argv[2]); //2D vector row lengths
	zzX = atoi(argv[3]); //x position of Patient 0
	zzY = atoi(argv[4]); //y position of Patient 0

	//Checks the range of values for the inputs
	checkArgs();

	//Declare the world parameters
	cout << "The world is " << x << " rows by " << y << " columns." << endl;

	//Create the initial infection
	vector<vector<Points1*>> world = initWorld();

	//print the world
	printWorld(world);
	//Infect the world
	infect(world);

	//Create objects for infection
	Zombies1 zombie;
	Humans1 human;

	return 0;
}

//Inital world printing:
vector<vector<Points1*>> initWorld() {
	vector<vector<Points1*>> World(x, vector<Points1*>(y));

	for (int i = 0; i < x; i++) {
		for (int j = 0; j < y; j++) {
			World[i][j] = new Humans1();
		}
	}

	delete World[zzX][zzY];
	World[zzX][zzY] = new Zombies1();

	return World;
}

void printWorld(const vector<vector<Points1*>>& World) {
	for (int i = 0; i < x; i++) {
		for (int j = 0; j < y; j++) {
			cout << World[i][j]->Infect_ed() << " ";
		}
		cout << endl;
	}
}

void infect(vector<vector<Points1*>>& World) {
	int dist = 1;
	bool done = false;

	//introduce a zombie
	Zombies1 tempZombie;

	while (!done) {
		done = true;

		for (int i = zzX - dist; i <= zzX + dist; i++) {
			for (int j = zzY - dist; j <= zzY + dist; j++) {

				if (i >= 0 && i < x && j >= 0 && j < y) {

					if (World[i][j]->getPoints() < tempZombie.getPoints()) {
						delete World[i][j];
						World[i][j] = new Zombies1();
					}
				}
			}
		}

		// Check for remaining humans
		for (int i = 0; i < x; i++) {
			for (int j = 0; j < y; j++) {
				if (World[i][j]->getPoints() < tempZombie.getPoints()) {
					done = false;
				}
			}
		}

		printWorld(World);
		cout << endl;

		dist++;
	}
}

void checkArgs() {
	if (x <= 0 || y <= 0) {
		cout << "Invalid grid dimensions." << endl;
		exit(1);
	}
	if (zzX < 0 || zzX >= x || zzY < 0 || zzY >= y) {
		cout << "Invalid z position." << endl;
		exit(1);
	}
}
