#include "Zombies1.h"
#include <string>
#include <iostream>

Zombies1::Zombies1() {
    //Sets up the speed types for the zombies
    std::string speeds[] = { "Just a Head", "Crawler", "Slow Walker", "Walker", "Runner", "Sprinter" };

    //Sets up the strength types for the zombies in a list
    std::string strengths[] = { "Just a Head", "Average Person", "Body Builder", "Police Officer", "Farmer", "Brute" };

    //Sets the Aggression for the zombies into a list
    std::string aggressions[] = { "Just a Head", "Average Zombie", "Murderer", "Junkie", "Cocaine Bear", "Rabid" };

    //Set up the functions to randomize how "strong" the zombies will be in the world
    speed = speeds[rand() % 6];
    strength = strengths[rand() % 6];
    bite = aggressions[rand() % 6];

    calculatePoints();
}

int Zombies1::getSpeed(const std::string& speed) const {
    //Set up the speed and their values
    if (speed == "Sprinter") return 6;
    else if (speed == "Runner") return 5;
    else if (speed == "Walker") return 4;
    else if (speed == "Slow Walker") return 3;
    else if (speed == "Crawler") return 2;
    else if (speed == "Just a Head") return 1;
    return 0;
}

int Zombies1::getStrength(const std::string& strength) const {
    //Set up the Strength of the Zombie
    if (strength == "Brute") return 6;
    else if (strength == "Farmer") return 5;
    else if (strength == "Police Officer") return 4;
    else if (strength == "Body Builder") return 3;
    else if (strength == "Average Person") return 2;
    else if (strength == "Just a Head") return 1;
    return 0;
}

int Zombies1::getBite(const std::string& bite) const {
    //Set up the Aggression index
    if (bite == "Rabid") return 6;
    else if (bite == "Cocaine Bear") return 5;
    else if (bite == "Junkie") return 4;
    else if (bite == "Murderer") return 3;
    else if (bite == "Average Zombie") return 2;
    else if (bite == "Just a Head") return 1;
    return 0;
}

//Set up the Point system for the Zombies
void Zombies1::calculatePoints() {
    points = 0;
    points = getSpeed(speed) 
        + getStrength(strength) 
        + getBite(bite);
}

//Returns the points that the given zombie has
int Zombies1::getPoints() const {
    return points;
}

//Sets the characters up for the zombies
char Zombies1::Infect_ed() {
    if (points == 0) {
        return 'w';
    }
    else if (points <= 3) {
        return 'W';
    }
    else if (points <= 8) {
        return 'z';
    }
    else if (points <= 14) {
        return 'Z';
    }
    else if (points <= 18) {
        return 'V';
    }
    //puts a check in place
    else {
        return -1;
    }
}

